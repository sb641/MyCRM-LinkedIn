{
  "name": "mycrm-linkedin-mvp",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "node scripts/clean-workspace.mjs",
    "clean:all": "node scripts/clean-workspace.mjs --include-runtime-data",
    "db:generate": "pnpm --filter @mycrm/db db:generate",
    "db:migrate": "pnpm --filter @mycrm/db db:migrate",
    "db:seed": "pnpm --filter @mycrm/db db:seed",
    "dev": "pnpm -r --parallel --stream dev",
    "dev:web": "pnpm --filter @mycrm/web dev",
    "dev:worker": "pnpm --filter @mycrm/worker dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "test:e2e": "pnpm --filter @mycrm/web test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.2",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
